{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "sqlite": {
            "type": "local",
            "command": ["npx", "-y", "mcp-sqlite-tools"],
            "environment": {
                "SQLITE_DEFAULT_PATH": "/Users/a1/Documents/Arlecchino/arlecchino/data",
                "SQLITE_ALLOW_ABSOLUTE_PATHS": "true"
            },
            "enabled": true
        },
        "filesystem": {
            "type": "local",
            "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/a1/Documents/Arlecchino"],
            "enabled": false
        },
        "github": {
            "type": "local",
            "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
            "environment": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
            },
            "enabled": false
        },
        "tree-sitter": {
            "type": "local",
            "command": ["uvx", "mcp-server-tree-sitter"],
            "enabled": true
        }
    }
}
