    {
      "id": "go:test:function",
      "name": "Test Function",
      "description": "Standard test function",
      "language": "go",
      "context": {
        "fileTypes": ["test"],
        "positions": ["after_imports", "file_start", "top_level"]
      },
      "trigger": {
        "type": "prefix",
        "value": "func"
      },
      "template": "func Test$NAME(t *testing.T) {\n\t$BODY\n}",
      "priority": 95
    },
    {
      "id": "go:test:table-driven",
      "name": "Table Test",
      "description": "Idiomatic table-driven test pattern",
      "language": "go",
      "context": {
        "fileTypes": ["test"],
        "positions": ["after_imports", "file_start", "top_level"]
      },
      "trigger": {
        "type": "prefix",
        "value": "func"
      },
      "template": "func Test$NAME(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    $INPUT_TYPE\n\t\texpected $OUTPUT_TYPE\n\t}{\n\t\t{\n\t\t\tname:     \"$CASE_NAME\",\n\t\t\tinput:    $INPUT,\n\t\t\texpected: $EXPECTED,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot := $FUNCTION(tt.input)\n\t\t\tif got != tt.expected {\n\t\t\t\tt.Errorf(\"$FUNCTION() = %v, want %v\", got, tt.expected)\n\t\t\t}\n\t\t})\n\t}\n}",
      "priority": 90
    },
    {
      "id": "go:benchmark:function",
