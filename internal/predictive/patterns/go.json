  "patterns": [
    {
      "id": "go:struct:definition",
      "name": "Struct",
      "description": "Define a new struct type with fields",
      "language": "go",
      "context": {
        "positions": ["after_imports", "file_start", "top_level"]
      },
      "trigger": {
        "type": "prefix",
        "value": "type"
      },
      "template": "type $NAME struct {\n\t$FIELD $TYPE\n}",
      "priority": 85
    },
