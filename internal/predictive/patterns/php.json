      "name": "Class Extends",
      "description": "Class extending another class",
      "language": "php",
      "context": {
        "positions": ["after_imports", "file_start", "top_level"]
      },
      "trigger": {
        "type": "prefix",
        "value": "class"
      },
      "template": "class $NAME extends $PARENT\n{\n\t$BODY\n}",
      "priority": 80
    },
    {
      "id": "php:class:constructor",
      "name": "Constructor",
      "description": "Constructor method",
      "language": "php",
      "context": {
