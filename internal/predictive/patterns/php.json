      "context": {
        "positions": ["method_body"]
      },
      "trigger": {
        "type": "prefix",
        "value": "for"
      },
      "template": "foreach ($$ARRAY as $$ITEM) {\n\t$BODY\n}",
      "priority": 85
    },
    {
      "id": "php:if:statement",
      "name": "If Statement",
      "description": "Conditional statement",
      "language": "php",
      "context": {
        "positions": ["method_body"]
      },
      "trigger": {
        "type": "prefix",
        "value": "if"
      },
      "template": "if ($CONDITION) {\n\t$BODY\n}",
      "priority": 85
