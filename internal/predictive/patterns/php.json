{
  "version": "1.0",
  "name": "PHP Patterns",
  "description": "Core PHP language patterns",
  "language": "php",
  "patterns": [
    {
      "id": "php:class:definition",
      "name": "Class Definition",
      "description": "Define a new PHP class",
      "language": "php",
      "context": {
        "positions": ["after_imports", "file_start", "top_level"]
      },
      "trigger": {
        "type": "prefix",
        "value": "class"
      },
      "template": "class $NAME\n{\n\t$BODY\n}",
      "priority": 85
    },
    {
